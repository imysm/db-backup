# ===========================================
# db-backup 环境变量配置
# ===========================================
# 本文件仅列出可通过环境变量覆盖的配置项。
# 主要配置请通过 config.yaml 管理（参见 configs/config.yaml）。

# ---------- 必要配置 ----------

# 配置文件路径（默认: configs/config.yaml）
# CONFIG_PATH=/etc/db-backup/config.yaml

# ---------- 可选配置 ----------

# 工作目录，备份文件临时存放位置（默认: /tmp/db-backup）
# DB_BACKUP_WORK_DIR=/var/lib/db-backup

# 默认时区（默认: Asia/Shanghai）
# DB_BACKUP_DEFAULT_TZ=Asia/Shanghai

# 最大并发备份数（默认: 5）
# DB_BACKUP_MAX_CONCURRENT=5

# 单次备份超时时间，单位秒（默认: 7200，即2小时）
# DB_BACKUP_TIMEOUT=7200

# ---------- 日志配置 ----------

# 日志级别: debug / info / warn / error（默认: info）
# DB_BACKUP_LOG_LEVEL=info

# 日志格式: console / json（默认: console）
# DB_BACKUP_LOG_FORMAT=console

# 日志文件路径（留空则输出到 stdout）
# DB_BACKUP_LOG_FILE=/var/log/db-backup/app.log

# ---------- 安全配置 ----------

# 加密密钥（用于备份文件加密，建议32字节以上）
# 如果启用加密功能，必须设置此变量
# DB_BACKUP_ENCRYPTION_KEY=your-encryption-key-here

# API 认证密钥
# DB_BACKUP_API_SECRET=your-api-secret-here
